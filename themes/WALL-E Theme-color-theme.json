{
	"name": "WALL-E Theme",
	"semanticHighlighting": true,
	"colors": {
		"editor.background": "#1C1A18",
		"editor.foreground": "#D4CEC2",
		"editor.lineHighlightBackground": "#292521",
		"editor.selectionBackground": "#3A342D",
		"editor.inactiveSelectionBackground": "#3A342D99",
		"editorCursor.foreground": "#D4CEC2",
		"editorWhitespace.foreground": "#3A342D",
		"editorIndentGuide.background1": "#292521",
		"editorIndentGuide.activeBackground1": "#3A342D",
		"sideBar.background": "#201D1A",
		"sideBar.foreground": "#D4CEC2",
		"sideBarTitle.foreground": "#D4CEC2",
		"activityBar.background": "#181614",
		"activityBar.foreground": "#D4CEC2",
		"activityBar.inactiveForeground": "#8F98A1",
		"activityBarBadge.background": "#C7864A",
		"activityBarBadge.foreground": "#1C1A18",
		"titleBar.activeBackground": "#201D1A",
		"titleBar.activeForeground": "#D4CEC2",
		"titleBar.inactiveBackground": "#181614",
		"titleBar.inactiveForeground": "#8F98A1",
		"statusBar.background": "#181614",
		"statusBar.foreground": "#D4CEC2",
		"editorGroupHeader.tabsBackground": "#201D1A",
		"tab.activeBackground": "#1C1A18",
		"tab.activeForeground": "#D4CEC2",
		"tab.inactiveBackground": "#201D1A",
		"tab.inactiveForeground": "#8F98A1",
		"panel.background": "#201D1A",
		"panel.border": "#292521",
		"list.activeSelectionBackground": "#3A342D",
		"list.inactiveSelectionBackground": "#292521",
		"list.hoverBackground": "#292521",
		"editorBracketHighlight.foreground1": "#C7864A",
		"editorBracketHighlight.foreground2": "#B05F4A",
		"editorBracketHighlight.foreground3": "#8A749C",
		"editorBracketHighlight.foreground4": "#C7864A",
		"editorBracketHighlight.foreground5": "#B05F4A",
		"editorBracketHighlight.foreground6": "#8A749C",
		"editorBracketPairGuide.activeBackground1": "#C7864A",
		"editorBracketPairGuide.activeBackground2": "#B05F4A",
		"editorBracketPairGuide.activeBackground3": "#8A749C",
		"editorBracketPairGuide.background1": "#C7864A33",
		"editorBracketPairGuide.background2": "#B05F4A33",
		"editorBracketPairGuide.background3": "#8A749C33"
	},
	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#6F7D6B"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.word",
				"storage",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#B05F4A"
			}
		},
		{
			"name": "Variables and plain identifiers",
			"scope": [
				"variable",
				"identifier"
			],
			"settings": {
				"foreground": "#D4CEC2"
			}
		},
		{
			"name": "Parameters and member variables",
			"scope": [
				"variable.parameter",
				"variable.other.property",
				"variable.object.property",
				"meta.object-literal.key"
			],
			"settings": {
				"foreground": "#B49A78"
			}
		},
		{
			"name": "Functions and methods",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"variable.function",
				"support.function"
			],
			"settings": {
				"foreground": "#C7864A"
			}
		},
		{
			"name": "Types",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.struct",
				"entity.name.enum",
				"support.type",
				"support.class",
				"storage.type",
				"meta.generic",
				"entity.name.type.template"
			],
			"settings": {
				"foreground": "#8F98A1"
			}
		},
		{
			"name": "Namespaces",
			"scope": [
				"entity.name.namespace",
				"support.other.namespace",
				"meta.namespace"
			],
			"settings": {
				"foreground": "#7F6B6B"
			}
		},
		{
			"name": "Numbers and constants",
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character",
				"constant.other"
			],
			"settings": {
				"foreground": "#6D93B0"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#B9A055"
			}
		},
		{
			"name": "Operators and punctuation",
			"scope": [
				"keyword.operator",
				"punctuation",
				"delimiter"
			],
			"settings": {
				"foreground": "#D4CEC2"
			}
		},
		{
			"name": "Preprocessor, macros, attributes",
			"scope": [
				"entity.name.function.preprocessor",
				"meta.preprocessor",
				"keyword.control.directive",
				"punctuation.definition.directive",
				"entity.other.attribute-name",
				"storage.modifier.attribute",
				"support.annotation"
			],
			"settings": {
				"foreground": "#8A749C"
			}
		},
		{
			"name": "HTML tags",
			"scope": [
				"entity.name.tag",
				"meta.tag",
				"punctuation.definition.tag",
				"punctuation.definition.tag.begin",
				"punctuation.definition.tag.end"
			],
			"settings": {
				"foreground": "#B05F4A"
			}
		},
		{
			"name": "HTML and CSS attributes",
			"scope": [
				"entity.other.attribute-name",
				"support.type.property-name",
				"meta.attribute-with-value.attribute-name"
			],
			"settings": {
				"foreground": "#B49A78"
			}
		}
	],
	"semanticTokenColors": {
		"comment": "#6F7D6B",
		"keyword": "#B05F4A",
		"operator": "#D4CEC2",
		"variable": "#D4CEC2",
		"variable.readonly": "#6D93B0",
		"parameter": "#B49A78",
		"property": "#B49A78",
		"property.readonly": "#6D93B0",
		"function": "#C7864A",
		"method": "#C7864A",
		"number": "#6D93B0",
		"enumMember": "#6D93B0",
		"string": "#B9A055",
		"type": "#8F98A1",
		"type.defaultLibrary": "#8F98A1",
		"class": "#8F98A1",
		"struct": "#8F98A1",
		"enum": "#8F98A1",
		"typeParameter": "#8F98A1",
		"namespace": "#7F6B6B",
		"macro": "#8A749C",
		"decorator": "#8A749C"
	}
}