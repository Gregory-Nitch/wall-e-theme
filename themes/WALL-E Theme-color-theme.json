	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#6F7D6B"
			}
		},
		{
			"name": "Keywords",
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.control.flow",
				"keyword.operator.cast.const_cast.cpp",
				"keyword.operator.cast.dynamic_cast.cpp",
				"keyword.operator.cast.reinterpret_cast.cpp",
				"keyword.operator.cast.static_cast.cpp",
				"keyword.other.namespace.definition.cpp",
				"markup.heading",
				"markup.heading.markdown",
				"entity.name.section.markdown",
				"markup.heading.markdown punctuation.definition.heading.markdown",
				"punctuation.definition.heading.markdown",
				"keyword.operator.word",
				"storage",
				"storage.type",
				"storage.type.class.cpp",
				"storage.type.enum.enum-key.class.cpp",
				"storage.type.enum.cpp",
				"storage.type.namespace.definition.cpp",
				"storage.type.struct.cpp",
				"storage.modifier",
				"storage.modifier.specifier",
				"storage.type.primitive",
				"keyword.other.template"
			],
			"settings": {
				"foreground": "#B05F4A"
			}
		},
		{
			"name": "Variables and plain identifiers",
			"scope": [
				"variable",
				"identifier"
			],
			"settings": {
				"foreground": "#B5AFA6"
			}
		},
		{
			"name": "Parameters and member variables",
			"scope": [
				"variable.parameter",
				"variable.other.property",
				"variable.other.member",
				"variable.object.property",
				"meta.object-literal.key"
			],
			"settings": {
				"foreground": "#B49A78"
			}
		},
		{
			"name": "Functions and methods",
			"scope": [
				"entity.name.function",
				"entity.name.function.member",
				"keyword.other.operator.overload.cpp",
				"markup.bold.markdown",
				"markup.bold.markdown punctuation.definition.bold",
				"markup.list punctuation.definition.list.begin.markdown",
				"punctuation.definition.list.begin.markdown",
				"meta.function.definition entity.name.function",
				"meta.function-call",
				"meta.function-call entity.name.function",
				"variable.function",
				"support.function"
			],
			"settings": {
				"foreground": "#C7864A"
			}
		},
		{
			"name": "Types",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.struct",
				"entity.name.enum",
				"entity.name.union",
				"entity.name.scope-resolution.function.call.cpp",
				"support.type.primitive",
				"support.type",
				"support.class",
				"storage.type",
				"storage.type.template",
				"meta.generic",
				"entity.name.type.template"
			],
			"settings": {
				"foreground": "#8F98A1"
			}
		},
		{
			"name": "Namespaces",
			"scope": [
				"entity.name.namespace",
				"entity.name.namespace.cpp",
				"entity.name.scope-resolution.cpp",
				"support.other.namespace",
				"meta.namespace"
			],
			"settings": {
				"foreground": "#7F6B6B"
			}
		},
		{
			"name": "Numbers and constants",
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.language.boolean",
				"constant.language.nullptr",
				"constant.character",
				"constant.other",
				"support.constant"
			],
			"settings": {
				"foreground": "#6D93B0"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#B9A055"
			}
		},
		{
			"name": "Operators and punctuation",
			"scope": [
				"keyword.operator",
				"punctuation",
				"delimiter",
				"punctuation.separator.namespace.access"
			],
			"settings": {
				"foreground": "#B5AFA6"
			}
		},
		{
			"name": "Preprocessor, macros, attributes",
			"scope": [
				"entity.name.function.preprocessor",
				"meta.preprocessor",
				"markup.italic.markdown",
				"markup.italic.markdown punctuation.definition.italic",
				"keyword.control.directive",
				"keyword.control.directive.defined",
				"punctuation.definition.directive",
				"entity.other.attribute-name",
				"storage.modifier.attribute",
				"meta.attribute",
				"support.annotation"
			],
			"settings": {
				"foreground": "#8A749C"
			}
		},
		{
			"name": "HTML tags",
			"scope": [
				"entity.name.tag",
				"meta.tag",
				"punctuation.definition.tag",
				"punctuation.definition.tag.begin",
				"punctuation.definition.tag.end"
			],
			"settings": {
				"foreground": "#B05F4A"
			}
		},
		{
			"name": "HTML and CSS attributes",
			"scope": [
				"entity.other.attribute-name",
				"support.type.property-name",
				"meta.attribute-with-value.attribute-name"
			],
			"settings": {
				"foreground": "#B49A78"
			}
		}
	],
	"semanticTokenColors": {
		"comment": "#6F7D6B",
		"keyword": "#B05F4A",
		"operator": "#B5AFA6",
		"variable": "#B5AFA6",
		"variable.global": "#B49A78",
		"variable.defaultLibrary": "#B5AFA6",
		"variable.readonly": "#6D93B0",
		"parameter": "#B49A78",
		"property": "#B49A78",
		"property.readonly": "#6D93B0",
		"function": "#C7864A",
		"method": "#C7864A",
		"memberOperatorOverload": "#C7864A",
		"macro": "#8A749C",
		"number": "#6D93B0",
		"enumMember": "#6D93B0",
		"string": "#B9A055",
		"type": "#8F98A1",
		"type.defaultLibrary": "#8F98A1",
		"class": "#8F98A1",
		"struct": "#8F98A1",
		"enum": "#8F98A1",
		"typeParameter": "#8F98A1",
		"namespace": "#7F6B6B",
		"decorator": "#8A749C"
	}
}